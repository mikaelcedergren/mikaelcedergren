{
  "name": "mikaelcedergren.com",
  "version": "1.0.0",
  "private": true,
  "description": "mikaelcedergren.com — Angular 22 SSG site (prerendered to dist/browser, served by Express on the Mac mini). Migrated off CodeKit.",
  "author": "Mikael Cedergren <michael@wargr.com>",
  "license": "UNLICENSED",
  "homepage": "https://mikaelcedergren.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaelcedergren/mikaelcedergren.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "ng serve --configuration local --host 127.0.0.1 --port 4250",
    "build": "ng build --configuration prod && node scripts/flatten.mjs",
    "build:local": "ng build --configuration local && node scripts/flatten.mjs",
    "start": "node server/index.mjs",
    "serve": "node server/index.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/localize": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-server": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/ssr": "^22.0.3",
    "@mikaelcedergren/cx-framework": "github:mikaelcedergren/cx-framework#main",
    "compression": "^1.7.5",
    "express": "^4.21.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0",
    "@angular/cdk": "^22.0.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@playwright/test": "1.60.0",
    "parse5": "^8.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
