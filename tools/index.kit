<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Basic Page</title>
    <link rel="stylesheet" href="styles/styles.css">
</head>

<body>
    <div id="wrapper">

        <h1>Hello</h1>
        <label for="input-basic">Label</label>
        <input id="input-basic" type="text" class="textfield" placeholder="Placeholder">
        <div>
            <a-tag class="tag">
                <label>This is a tag</label>
                <div class="remove-button">X</div>
            </a-tag>
        </div>
    </div>
</body>
</html>